# Copy this file to .env and fill in the values

# GitHub API token (for reading student repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab API token (for GitLab-hosted labs, optional)
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API Key (for LLM checks)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=google/gemini-2.5-flash-lite

# Telegram bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF...

# SQLite database path (inside the container, mounted via volume)
# DB_PATH=/app/data/bot.db

# Active labs (comma-separated)
ACTIVE_LABS=lab-01,lab-02,lab-03,lab-04

# Attempts per task
MAX_ATTEMPTS_PER_TASK=12

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=
