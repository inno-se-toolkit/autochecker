end/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/docs%2Flab-02-proof.md", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/docs%2Flab-02-proof.md", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/docs%2Flab-02-proof.md?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -4,23 +4,69 @@ Use this file to collect evidence for TA checks (commands you ran + outputs / sc\n \n ## Local run\n \n-- Status endpoint:\n-- Items endpoint:\n+- Status endpoint: `GET /status` returns `{\"status\": \"ok\"}`\n+- Items endpoint: `GET /items/lab-02-run-local` originally returned 404.\n - Failing test output:\n \n+```\n+tests/test_items.py::test_get_item_by_id FAILED\n+E       assert 404 == 200\n+E        +  where 404 = <Response [404 Not Found]>.status_code\n+```\n+\n ## Bug investigation\n \n-- Summary:\n-- Steps to reproduce:\n-- Expected vs actual:\n+- Summary: The endpoint `/items/{item_id}` returned 404 for existing items (like `lab-02-run-local`).\n+- Cause: The function `find_item_by_id` in `item_service.py` was comparing the requested `item_id` against `item.type` instead of `item.id`.\n+- Fix: Changed `item.type == item_id` to `item.id == item_id`.\n+- Verification (tests passed):\n+\n+```\n+tests/test_items.py::test_get_course_by_id PASSED\n+tests/test_items.py::test_list_items PASSED\n+tests/test_items.py::test_get_item_by_id PASSED\n+tests/test_status.py::test_status PASSED\n+```\n \n ## Deployment (Docker Compose)\n \n-- Docker + Compose versions:\n+- Docker + Compose versions: `Docker version 28.2.2`, `Docker Compose version v2.37.1`\n - `docker compose up` output:\n+```\n+[+] Running 4/4\n+ \u2714 app                      Built\n+ \u2714 Network myapp_default    Created\n+ \u2714 Container myapp-app-1    Started\n+ \u2714 Container myapp-nginx-1  Started\n+```\n - `docker compose ps` output:\n+```\n+NAME            IMAGE               COMMAND                  SERVICE  STATUS   PORTS\n+myapp-app-1     myapp-app           \"uv run uvicorn src.\u2026\"   app      Up       8000/tcp\n+myapp-nginx-1   nginx:1.27-alpine   \"/docker-entrypoint.\u2026\"   nginx    Up       0.0.0.0:80->80/tcp\n+```\n \n ## Nginx\n \n - `nginx -t` output (inside container):\n+```\n+nginx: the configuration file /etc/nginx/nginx.conf syntax is ok\n+nginx: configuration file /etc/nginx/nginx.conf test is successful\n+```\n+\n+## Debug logs\n+\n+- `docker compose logs` output:\n+```\n+app-1  | INFO:     Started server process [1]\n+app-1  | INFO:     Uvicorn running on http://0.0.0.0:8000\n+nginx-1  | /docker-entrypoint.sh: Configuration complete; ready for start up\n+```\n+\n+\n+## Stretch Goal: Task 10 (Outcomes API + HTTPS)\n \n+- Implementation: Added `src/app/models/outcome.py`, `service`, `router`.\n+- Tests: `tests/test_outcomes.py` passed.\n+- Deployment: Replaced Nginx with **Caddy** for automatic HTTPS.\n+- HTTPS Verification: Application is accessible at `https://46.224.249.95.nip.io/docs`."}, {"sha": "a8d520ebadde9c2cf030951b419ffdce66ef76df", "filename": "src/app/models/outcome.py", "status": "added", "additions": 14, "deletions": 0, "changes": 14, "blob_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Fmodels%2Foutcome.py", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Fmodels%2Foutcome.py", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/src%2Fapp%2Fmodels%2Foutcome.py?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -0,0 +1,14 @@\n+from typing import Dict, List, Optional\n+from pydantic import BaseModel\n+\n+class Outcome(BaseModel):\n+    id: str\n+    type: str\n+    titles: Dict[str, str]\n+    descriptions: Dict[str, str]\n+    related_item_ids: Optional[List[str]] = None\n+    coverage_notes: Optional[Dict[str, str]] = None\n+    suboutcomes: Optional[List[\"Outcome\"]] = None\n+\n+    class Config:\n+        populate_by_name = True"}, {"sha": "c8562c7b86f91b5c4f2b4d1746abf631dcac3717", "filename": "src/app/routers/outcomes.py", "status": "added", "additions": 38, "deletions": 0, "changes": 38, "blob_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Frouters%2Foutcomes.py", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Frouters%2Foutcomes.py", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/src%2Fapp%2Frouters%2Foutcomes.py?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -0,0 +1,38 @@\n+from typing import Dict, List\n+from fastapi import APIRouter, HTTPException\n+\n+from app.models.outcome import Outcome\n+from app.services.outcome_service import get_outcomes_data, find_outcome_by_id\n+\n+router = APIRouter()\n+\n+\n+@router.get(\"\", response_model=Dict[str, List[Outcome]])\n+def get_all_outcomes():\n+    \"\"\"Get all learning outcomes.\n+    \n+    Returns:\n+        A dictionary containing a list of all outcomes.\n+    \"\"\"\n+    return get_outcomes_data()\n+\n+\n+@router.get(\"/{outcome_id}\", response_model=Outcome)\n+def get_outcome(outcome_id: str):\n+    \"\"\"Get a specific outcome by its id.\n+    \n+    Searches through the outcome tree to find the matching id.\n+    \n+    Args:\n+        outcome_id: The unique identifier of the outcome.\n+        \n+    Returns:\n+        The matching outcome.\n+        \n+    Raises:\n+        HTTPException: 404 if the outcome is not found.\n+    \"\"\"\n+    outcome = find_outcome_by_id(outcome_id)\n+    if not outcome:\n+        raise HTTPException(status_code=404, detail=\"Outcome not found\")\n+    return outcome"}, {"sha": "596db3060bd74f65348f512e8b0fc99386f67119", "filename": "src/app/services/item_service.py", "status": "modified", "additions": 1, "deletions": 1, "changes": 2, "blob_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Fservices%2Fitem_service.py", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Fservices%2Fitem_service.py", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/src%2Fapp%2Fservices%2Fitem_service.py?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -56,6 +56,6 @@ def find_item_by_id(item_id: str) -> Optional[Item]:\n             return course\n \n         for item in _iter_item_tree(course):\n-            if item.type == item_id:\n+            if item.id == item_id:\n                 return item\n     return None"}, {"sha": "debd99b62551fe6366af1489d1310ab6ce1a9cca", "filename": "src/app/services/outcome_service.py", "status": "added", "additions": 37, "deletions": 0, "changes": 37, "blob_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Fservices%2Foutcome_service.py", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fapp%2Fservices%2Foutcome_service.py", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/src%2Fapp%2Fservices%2Foutcome_service.py?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -0,0 +1,37 @@\n+import json\n+from functools import lru_cache\n+from pathlib import Path\n+from typing import Dict, Iterable, List, Optional\n+\n+from app.models.outcome import Outcome\n+\n+DATA_PATH = Path(__file__).resolve().parent.parent / \"data\" / \"outcomes.json\"\n+\n+\n+def _iter_outcome_tree(outcome: Outcome) -> Iterable[Outcome]:\n+    \"\"\"Recursively iterate over an outcome and all its nested children.\"\"\"\n+    yield outcome\n+    if outcome.suboutcomes:\n+        for child in outcome.suboutcomes:\n+            yield from _iter_outcome_tree(child)\n+\n+\n+@lru_cache\n+def get_outcomes_data() -> Dict[str, List[Outcome]]:\n+    \"\"\"Load and return outcomes data from the JSON file.\"\"\"\n+    with open(DATA_PATH, \"r\", encoding=\"utf-8\") as handle:\n+        raw = json.load(handle)\n+    \n+    # map dictionary to model\n+    outcomes_list = [Outcome.model_validate(o) for o in raw.get(\"outcomes\", [])]\n+    return {\"outcomes\": outcomes_list}\n+\n+\n+def find_outcome_by_id(outcome_id: str) -> Optional[Outcome]:\n+    \"\"\"Find an outcome by its id, searching through all outcomes and their nested items.\"\"\"\n+    data = get_outcomes_data()\n+    for outcome in data[\"outcomes\"]:\n+        for item in _iter_outcome_tree(outcome):\n+            if item.id == outcome_id:\n+                return item\n+    return None"}, {"sha": "6820b1d21139e99e5ffe87db170959e165a5eb2a", "filename": "src/main.py", "status": "modified", "additions": 2, "deletions": 1, "changes": 3, "blob_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fmain.py", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/src%2Fmain.py", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/src%2Fmain.py?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -5,7 +5,7 @@\n \"\"\"\n \n from fastapi import FastAPI\n-from app.routers import items, status\n+from app.routers import items, status, outcomes\n \n app = FastAPI(\n     title=\"Course Material Service\",\n@@ -15,3 +15,4 @@\n \n app.include_router(status.router, tags=[\"status\"])\n app.include_router(items.router, prefix=\"/items\", tags=[\"items\"])\n+app.include_router(outcomes.router, prefix=\"/outcomes\", tags=[\"outcomes\"])"}, {"sha": "c4c7b15db650f7a6557ab73798cebc03c5b24925", "filename": "tests/test_outcomes.py", "status": "added", "additions": 29, "deletions": 0, "changes": 29, "blob_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/blob/96c9d0e6adf6877db5569678b38849412a7e18ce/tests%2Ftest_outcomes.py", "raw_url": "https://github.com/Nurassyl28/lab-02-fix-and-deploy-backend/raw/96c9d0e6adf6877db5569678b38849412a7e18ce/tests%2Ftest_outcomes.py", "contents_url": "https://api.github.com/repos/Nurassyl28/lab-02-fix-and-deploy-backend/contents/tests%2Ftest_outcomes.py?ref=96c9d0e6adf6877db5569678b38849412a7e18ce", "patch": "@@ -0,0 +1,29 @@\n+from fastapi.testclient import TestClient\n+from main import app\n+\n+def test_get_all_outcomes():\n+    client = TestClient(app)\n+    response = client.get(\"/outcomes\")\n+    \n+    assert response.status_code == 200\n+    payload = response.json()\n+    assert \"outcomes\" in payload\n+    assert isinstance(payload[\"outcomes\"], list)\n+    assert len(payload[\"outcomes\"]) > 0\n+    assert payload[\"outcomes\"][0][\"id\"] == \"course-outcomes\"\n+\n+def test_get_outcome_by_id():\n+    client = TestClient(app)\n+    response = client.get(\"/outcomes/lab-02-outcome-local-dev\")\n+    \n+    assert response.status_code == 200\n+    payload = response.json()\n+    assert payload[\"id\"] == \"lab-02-outcome-local-dev\"\n+    assert \"suboutcomes\" in payload\n+    assert isinstance(payload[\"suboutcomes\"], list)\n+\n+def test_get_outcome_not_found():\n+    client = TestClient(app)\n+    response = client.get(\"/outcomes/non-existent-outcome\")\n+    \n+    assert response.status_code == 404"}]